# ─────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# Google Cloud Storage
GCS_PROJECT_ID=united-monument-388200
GCS_BUCKET_NAME=face-emotion-dataset
GCS_KEY_PATH=secrets/gcs_key.json   # path to your service account JSON

# Model thresholds
SVM_CONFIDENCE_THRESHOLD=0.70
COSINE_SIMILARITY_THRESHOLD=0.50
EMOTION_CONFIDENCE_THRESHOLD=55.0

# Runtime
LOG_LEVEL=INFO
LOG_DIR=logs
ENV=development      # development | staging | production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Security & Limits
API_KEY=netsmartz.net
MAX_UPLOAD_SIZE_MB=5
MAX_RUNTIME_MINUTES=10
LOW_LIGHT_THRESHOLD=40
